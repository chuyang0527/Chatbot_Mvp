#!/bin/bash
# Pre-commit hook: 检查代码规范

echo "🔍 运行 pre-commit 检查..."

# 检查是否使用了 print()
echo "检查是否使用了 print()..."
if grep -r "print(" src/ --include="*.py" | grep -v "console.print"; then
    echo "❌ 错误：代码中使用了 print() 进行调试！"
    echo "请使用 logger 模块替代 print()"
    echo "详见: LOGGING_GUIDE.md"
    exit 1
fi
echo "✅ 未发现 print() 使用"

# 检查代码格式
echo "检查代码格式..."
if command -v black &> /dev/null; then
    black --check src/ 2>&1 | head -n 10
    if [ $? -ne 0 ]; then
        echo "❌ 代码格式不符合规范"
        echo "运行: uv run black src/"
        exit 1
    fi
    echo "✅ 代码格式检查通过"
else
    echo "⚠️  未安装 black，跳过格式检查"
fi

# 检查 lint
echo "检查代码质量..."
if command -v ruff &> /dev/null; then
    ruff check src/ --quiet
    if [ $? -ne 0 ]; then
        echo "❌ 代码质量检查失败"
        echo "运行: uv run ruff check src/"
        exit 1
    fi
    echo "✅ 代码质量检查通过"
else
    echo "⚠️  未安装 ruff，跳过 lint 检查"
fi

echo "✅ 所有检查通过！"
exit 0
